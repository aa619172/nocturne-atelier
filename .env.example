# Server
NODE_ENV=development
PORT=3001
SITE_URL=http://localhost:5173

# Auth — generate a long random string for production (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend (optional — Checkout Sessions redirect; publishable key for future Stripe.js use)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: override the newsletter endpoint (e.g. Formspree URL)
# VITE_NEWSLETTER_ENDPOINT=https://formspree.io/f/your-form-id

# Optional: SMTP for transactional email (not wired yet)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=correspondence@nocturneatelier.net
