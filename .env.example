# =============================================================================
# Local development — copy to .env and adjust
# =============================================================================

NODE_ENV=development
PORT=3001
SITE_URL=http://localhost:5173

# Auth — generate a long random string (e.g. openssl rand -base64 48)
JWT_SECRET=change-me-to-a-long-random-secret

# Stripe (test mode keys from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Frontend (optional — publishable key for future Stripe.js use)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: override the newsletter endpoint (e.g. Formspree URL)
# VITE_NEWSLETTER_ENDPOINT=https://formspree.io/f/your-form-id

# Optional: SMTP for transactional email (not wired yet)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=correspondence@nocturneatelier.net

# =============================================================================
# Hostinger Node.js Web App (production) — set in hPanel → Environment variables
# Do NOT commit real secrets to git.
# =============================================================================
#
# NODE_ENV=production
# PORT=                    # leave unset — Hostinger assigns PORT automatically
# HOST=0.0.0.0             # optional; default binds all interfaces
# SITE_URL=https://nocturneatelier.net
# JWT_SECRET=              # required — long random string (see HOSTINGER.md)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
#
# Stripe webhook URL: https://nocturneatelier.net/api/webhooks/stripe
