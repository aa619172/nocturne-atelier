{
  "name": "nocturne-atelier",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "main": "app.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "hostinger": {
    "framework": "express",
    "entry": "app.js",
    "output": "dist",
    "build": "npm run build",
    "start": "npm run start",
    "install": "npm ci --include=dev",
    "node": "20"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.js",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run dev:api\"",
    "build": "tsc -b && vite build",
    "start": "node app.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "postinstall": "node scripts/check-no-sqlite.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "speakeasy": "^2.0.0",
    "stripe": "^18.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
